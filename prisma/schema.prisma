generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String      @id @default(cuid())
  email      String      @unique
  username   String      @unique
  password   String
  savedMeals SavedMeal[]
  favorites Favorite[]
}

model Restaurant {
  id        String     @id @default(cuid())
  name      String
  logo      String?
  category  String
  menuItems MenuItem[]
}

model MenuItem {
  id           String          @id @default(cuid())
  restaurantId String
  restaurant   Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  itemName     String
  category     String
  servingSize  String
  calories     Float
  protein      Float
  carbs        Float
  fat          Float
  savedItems   SavedMealItem[]
}

model SavedMeal {
  id       String          @id @default(cuid())
  userId   String
  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  mealName String
  items    SavedMealItem[]
}

model SavedMealItem {
  mealId     String
  menuItemId String
  quantity   Float
  meal       SavedMeal @relation(fields: [mealId], references: [id], onDelete: Cascade)
  menuItem   MenuItem  @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  @@id([mealId, menuItemId])
}

model Favorite {
  id           String  @id @default(cuid())
  userId       String
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurantId String?
  menuItemId   String?
  savedMealId  String?
}
